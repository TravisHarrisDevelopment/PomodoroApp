<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWindowsForms>true</UseWindowsForms>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <RootNamespace>PomodoroApp</RootNamespace>
    <AssemblyName>PomodoroApp</AssemblyName>
    <AllowUnsafeBlocks>false</AllowUnsafeBlocks>
    <Optimize>true</Optimize>
    <PublishSingleFile>true</PublishSingleFile>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
  </PropertyGroup>

  <PropertyGroup>
    <ApplicationIcon>pomodoro.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="Alarm04.wav" />
  </ItemGroup>
  
  <ItemGroup>
    <EmbeddedResource Include="Alarm04.wav" />
    <EmbeddedResource Include="pomodoro.ico" />
  </ItemGroup>

</Project>
